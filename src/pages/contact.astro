---
import Layout from '../layouts/Layout.astro';

const email = 'contact@hookingpoint.kr';
---

<Layout title="Contact — Hooking Point">
	<div class="page contact">
		<h1>CONTACT</h1>
		<p class="lead">편집 의뢰, IP 자료 요청, 협업 제안 모두 환영합니다.</p>
		<a class="email-btn" href={`mailto:${email}`}>{email}</a>
	</div>
</Layout>

<style>
	.contact {
		padding-top: 1rem;
	}
	.lead {
		color: var(--muted);
		max-width: 34rem;
		margin-bottom: 2rem;
	}
	.email-btn {
		display: inline-block;
		border: 1px solid var(--accent);
		border-radius: 4px;
		padding: 0.9rem 1.5rem;
		font-weight: 700;
		font-size: 1.1rem;
		color: var(--accent);
	}
	.email-btn:hover {
		background: var(--accent);
		color: #fff;
	}
</style>
