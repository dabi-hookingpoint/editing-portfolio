---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hooking Point">
	<div class="hero">
		<p class="logo">HOOKING POINT</p>
		<p class="vision">
			(우리의 비전 문구 작성 예정 — 알려주시면 반영할게요)
		</p>
		<a class="cta" href="/filmography">EDIT Filmography 보기 →</a>
	</div>
</Layout>

<style>
	.hero {
		min-height: calc(100vh - 4rem);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		gap: 2rem;
	}
	.logo {
		margin: 0;
		font-size: 1.1rem;
		font-weight: 700;
		letter-spacing: 0.2em;
	}
	.vision {
		margin: 0;
		max-width: 32rem;
		font-size: 1.3rem;
		line-height: 1.7;
		color: #fff;
	}
	.cta {
		display: inline-block;
		border: 1px solid #fff;
		border-radius: 4px;
		padding: 0.8rem 1.5rem;
		text-decoration: none;
		font-weight: 600;
	}
	.cta:hover {
		background: #fff;
		color: #000;
	}
</style>
