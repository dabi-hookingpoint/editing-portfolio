---
interface Props {
	title: string;
}

const { title } = Astro.props;
const navItems = [
	{ href: '/', label: 'HOME' },
	{ href: '/filmography', label: 'EDITING · WORKS' },
	{ href: '/ip-development', label: 'IP DEVELOPMENT' },
	{ href: '/about', label: 'ABOUT' },
	{ href: '/contact', label: 'CONTACT' },
];
const currentPath = Astro.url.pathname;
---

<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link
			rel="stylesheet"
			as="style"
			crossorigin
			href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css"
		/>
		<style is:global>
			:root {
				color-scheme: dark;
				font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, Roboto,
					'Helvetica Neue', 'Segoe UI', 'Apple SD Gothic Neo', sans-serif;

				--bg: #0f1c3f;
				--fg: #f4f5f7;
				--muted: #aab4cc;
				--accent: #5b8def;
				--accent-dim: rgba(91, 141, 239, 0.16);
				--border: #29396b;
			}
			body {
				margin: 0;
				line-height: 1.6;
				background: var(--bg);
				color: var(--fg);
			}
			a {
				color: inherit;
				text-decoration: none;
			}
			.page {
				max-width: 1100px;
				margin-inline: auto;
				padding: 0 2rem 4rem;
			}
			.site-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				max-width: 1100px;
				margin-inline: auto;
				padding: 2rem;
				gap: 2rem;
			}
			.site-header .logo {
				font-weight: 700;
				letter-spacing: 0.15em;
				font-size: 0.95rem;
				flex-shrink: 0;
			}
			.site-nav {
				display: flex;
				flex-wrap: wrap;
				gap: 1.5rem;
			}
			.site-nav a {
				font-size: 0.8rem;
				font-weight: 600;
				letter-spacing: 0.05em;
				color: var(--muted);
				transition: color 0.15s ease;
			}
			.site-nav a:hover {
				color: var(--fg);
			}
			.site-nav a[aria-current='page'] {
				color: var(--accent);
			}
			.back-link {
				display: inline-block;
				margin-bottom: 1.5rem;
				color: var(--muted);
				transition: color 0.15s ease;
			}
			.back-link:hover {
				color: var(--fg);
			}
			.site-footer {
				max-width: 1100px;
				margin-inline: auto;
				padding: 2rem;
				border-top: 1px solid var(--border);
				color: var(--muted);
				font-size: 0.8rem;
			}
		</style>
	</head>
	<body>
		<header class="site-header">
			<a class="logo" href="/">HOOKING POINT</a>
			<nav class="site-nav">
				{navItems.map((item) => (
					<a href={item.href} aria-current={currentPath === item.href ? 'page' : undefined}>
						{item.label}
					</a>
				))}
			</nav>
		</header>
		<slot />
		<footer class="site-footer">© Hooking Point. All rights reserved.</footer>
	</body>
</html>
