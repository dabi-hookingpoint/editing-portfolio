---
interface Props {
	title: string;
}

const { title } = Astro.props;
const navItems = [
	{ href: '/', label: 'HOME' },
	{ href: '/filmography', label: 'EDITING · WORKS' },
	{ href: '/ip-development', label: 'IP DEVELOPMENT' },
	{ href: '/about', label: 'ABOUT' },
	{ href: '/contact', label: 'CONTACT' },
	{ href: '/login', label: 'LOGIN', id: 'nav-login' },
	{ href: '/admin', label: 'ADMIN', id: 'nav-admin' },
	{ href: '#', label: 'LOGOUT', id: 'nav-logout' },
];
const currentPath = Astro.url.pathname;
---

<html lang="ko">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link
			rel="stylesheet"
			as="style"
			crossorigin
			href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css"
		/>
		<style is:global>
			:root {
				color-scheme: light;
				font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, Roboto,
					'Helvetica Neue', 'Segoe UI', 'Apple SD Gothic Neo', sans-serif;

				--bg: #edf1f7;
				--surface: #ffffff;
				--fg: #2e3552;
				--muted: #5c6b8a;
				--heading: #2a3b8f;
				--accent: #ff6b4a;
				--accent-dim: rgba(255, 107, 74, 0.12);
				--border: #d7deea;
				--shadow: 0 1px 2px rgba(42, 59, 143, 0.06), 0 10px 24px rgba(42, 59, 143, 0.08);
				--shadow-hover: 0 2px 4px rgba(42, 59, 143, 0.07), 0 16px 32px rgba(42, 59, 143, 0.12);
			}
			body {
				margin: 0;
				line-height: 1.6;
				background: var(--bg);
				color: var(--fg);
			}
			h1,
			h2 {
				color: var(--heading);
			}
			a {
				color: inherit;
				text-decoration: none;
			}
			.page {
				max-width: 1100px;
				margin-inline: auto;
				padding: 0 2rem 4rem;
			}
			.site-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				max-width: 1100px;
				margin-inline: auto;
				padding: 2rem;
				gap: 2rem;
			}
			.site-header .logo {
				font-weight: 700;
				letter-spacing: 0.15em;
				font-size: 0.95rem;
				flex-shrink: 0;
				color: var(--heading);
			}
			.site-nav {
				display: flex;
				flex-wrap: wrap;
				gap: 1.5rem;
			}
			.site-nav a {
				font-size: 0.8rem;
				font-weight: 600;
				letter-spacing: 0.05em;
				color: var(--muted);
				transition: color 0.15s ease;
			}
			.site-nav a:hover {
				color: var(--fg);
			}
			.site-nav a[aria-current='page'] {
				color: var(--heading);
			}
			.back-link {
				display: inline-block;
				margin-bottom: 1.5rem;
				color: var(--muted);
				transition: color 0.15s ease;
			}
			.back-link:hover {
				color: var(--fg);
			}
			.site-footer {
				max-width: 1100px;
				margin-inline: auto;
				padding: 2rem;
				border-top: 1px solid var(--border);
				color: var(--muted);
				font-size: 0.8rem;
			}
		</style>
	</head>
	<body>
		<header class="site-header">
			<a class="logo" href="/">HOOKING POINT</a>
			<nav class="site-nav">
				{navItems.map((item) => (
					<a
						href={item.href}
						id={item.id}
						aria-current={currentPath === item.href ? 'page' : undefined}
						style={item.id ? 'display:none' : undefined}
					>
						{item.label}
					</a>
				))}
			</nav>
		</header>
		<slot />
		<footer class="site-footer">© Hooking Point. All rights reserved.</footer>
		<script>
			import { supabase } from '../lib/supabase';

			const loginLink = document.getElementById('nav-login');
			const adminLink = document.getElementById('nav-admin');
			const logoutLink = document.getElementById('nav-logout');

			async function updateNav() {
				const { data: { session } } = await supabase.auth.getSession();
				if (session) {
					loginLink?.style.setProperty('display', 'none');
					logoutLink?.style.removeProperty('display');

					const { data: profile } = await supabase
						.from('profiles')
						.select('role')
						.eq('id', session.user.id)
						.single();

					if (profile?.role === 'admin') {
						adminLink?.style.removeProperty('display');
					} else {
						adminLink?.style.setProperty('display', 'none');
					}
				} else {
					loginLink?.style.removeProperty('display');
					adminLink?.style.setProperty('display', 'none');
					logoutLink?.style.setProperty('display', 'none');
				}
			}

			updateNav();

			logoutLink?.addEventListener('click', async (e) => {
				e.preventDefault();
				await supabase.auth.signOut();
				window.location.href = '/';
			});
		</script>
	</body>
</html>
